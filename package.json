{
  "name": "@metyatech/workspace-agent-hub",
  "version": "0.2.1",
  "private": true,
  "description": "Windows + WSL tmux session fabric with a mobile-friendly web UI for AI agent CLI handoff",
  "type": "module",
  "bin": {
    "workspace-agent-hub": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metyatech/workspace-agent-hub.git"
  },
  "bugs": {
    "url": "https://github.com/metyatech/workspace-agent-hub/issues"
  },
  "homepage": "https://github.com/metyatech/workspace-agent-hub",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-hooks.ps1",
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-package.ps1",
    "typecheck": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/typecheck.ps1",
    "pretest:e2e": "npm run build && npm exec playwright install chromium",
    "test:unit": "npm exec vitest run src/__tests__",
    "test:e2e": "npm exec playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "lint": "npm run typecheck",
    "format": "npm exec prettier -- --write \"src/**/*.ts\" \"public/**/*.{html,js,webmanifest}\" \"*.{json,md,ts}\"",
    "format:check": "npm exec prettier -- --check \"src/**/*.ts\" \"public/**/*.{html,js,webmanifest}\" \"*.{json,md,ts}\"",
    "verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify.ps1",
    "web-ui": "node dist/cli.js web-ui"
  },
  "dependencies": {
    "@metyatech/managed-worktree-system": "^2.2.8",
    "@metyatech/thread-inbox": "^0.4.5",
    "commander": "^14.0.3",
    "marked": "^17.0.5",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "esbuild": "^0.27.3"
  }
}
