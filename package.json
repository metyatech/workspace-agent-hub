{
  "name": "@metyatech/workspace-agent-hub",
  "version": "0.1.0",
  "description": "Windows + WSL tmux session fabric with a mobile-friendly web UI for AI agent CLI handoff",
  "type": "module",
  "bin": {
    "workspace-agent-hub": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metyatech/workspace-agent-hub.git"
  },
  "bugs": {
    "url": "https://github.com/metyatech/workspace-agent-hub/issues"
  },
  "homepage": "https://github.com/metyatech/workspace-agent-hub",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "pretest:e2e": "npm run build && playwright install chromium",
    "test:unit": "vitest run src/__tests__",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "lint": "npm run typecheck",
    "format": "prettier --write \"src/**/*.ts\" \"public/**/*.{html,js,webmanifest}\" \"*.{json,md,ts}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"public/**/*.{html,js,webmanifest}\" \"*.{json,md,ts}\"",
    "verify": "npm run format:check && npm run lint && npm run build && npm run test",
    "web-ui": "node dist/cli.js web-ui"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "esbuild": "^0.27.3"
  }
}
